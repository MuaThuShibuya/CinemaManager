@{
    ViewData["Title"] = "Soát vé QR";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background-color: #0f0f0f;
        color: #e5e5e5;
        font-family: system-ui, -apple-system, BlinkMacSystemFont;
    }

    .scan-wrapper {
        max-width: 520px;
        margin: 80px auto;
        padding: 30px;
        background: #181818;
        border-radius: 16px;
        box-shadow: 0 0 40px rgba(0,0,0,.6);
    }

    #reader {
        width: 100%;
        margin-top: 20px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #333;
        display: none;
    }

    .btn-main {
        background-color: #e50914;
        border: none;
        font-weight: 600;
        padding: 12px;
    }

        .btn-main:hover {
            background-color: #b20710;
        }

    .order-box {
        background: #111;
        border: 1px solid #333;
        padding: 12px;
        border-radius: 8px;
        margin-top: 15px;
        text-align: center;
        font-size: 15px;
        letter-spacing: .5px;
        display: none;
    }
</style>

<div class="scan-wrapper text-center">
    <h4 class="mb-4">Soát vé bằng QR</h4>

    <button class="btn btn-main w-100" onclick="startScan()">
        Bắt đầu quét
    </button>

    <div id="rawBox" class="mt-3 p-2 border rounded bg-dark text-white" style="display:none">
        <div class="fw-bold mb-1">Dữ liệu QR đọc được:</div>
        <div id="rawQrText" style="word-break: break-all; color:#ffc107"></div>
    </div>

    <div id="orderBox" class="mt-3 p-2 border rounded bg-dark text-white" style="display:none">
        <div class="fw-bold mb-1">OrderId:</div>
        <div id="orderIdText" style="color:#0dcaf0"></div>
    </div>

    <div id="errorBox" class="alert alert-danger mt-3 d-none"></div>

    <div id="orderBox" class="order-box">
        <div class="text-secondary mb-1">Mã đơn</div>
        <strong id="orderIdText"></strong>
    </div>

    <div id="reader"></div>
</div>

<!-- MODAL -->
<div class="modal fade" id="resultModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">Thông tin vé</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody"></div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/html5-qrcode"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    let qrScanner;

    function showError(msg) {
        const box = document.getElementById("errorBox");
        box.innerText = msg;
        box.classList.remove("d-none");
    }

    function clearError() {
        document.getElementById("errorBox").classList.add("d-none");
    }

    async function startScan() {
        clearError();

        document.getElementById("rawBox").style.display = "none";
        document.getElementById("orderBox").style.display = "none";

        try {
            await navigator.mediaDevices.getUserMedia({ video: true });
        } catch {
            showError("Camera bị từ chối. Vui lòng cho phép camera.");
            return;
        }

        Html5Qrcode.getCameras().then(devices => {
            if (!devices.length) {
                showError("Không tìm thấy camera.");
                return;
            }

            document.getElementById("reader").style.display = "block";

            qrScanner = new Html5Qrcode("reader");
            qrScanner.start(
                devices[0].id,
                { fps: 10, qrbox: 260 },
                rawText => {

                    // 👉 HIỂN THỊ RAW DATA
                    document.getElementById("rawQrText").innerText = rawText;
                    document.getElementById("rawBox").style.display = "block";

                    // 👉 CHUẨN HÓA (CỰC QUAN TRỌNG)
                    let text = rawText
                        .trim()
                        .replace(/\r?\n/g, "")
                        .replace(/\s+/g, "");

                    // 👉 TRƯỜNG HỢP QR LÀ URL
                    if (text.includes("/")) {
                        text = text.substring(text.lastIndexOf("/") + 1);
                    }

                    const regex = /^ORDER_[a-zA-Z0-9]+$/;

                    if (!regex.test(text)) {
                        showError("QR không chứa mã vé hợp lệ.");
                        qrScanner.stop();
                        return;
                    }

                    // 👉 HIỂN THỊ ORDER ID
                    document.getElementById("orderIdText").innerText = text;
                    document.getElementById("orderBox").style.display = "block";

                    qrScanner.stop();
                    ajaxCheck(text);
                }
            );
        });
    }

    function ajaxCheck(orderId) {
        fetch('/TicketScan/AjaxCheck', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(orderId)
        })
        .then(r => {
            if (!r.ok) throw "error";
            return r.json();
        })
        .then(res => showResult(res))
        .catch(() => showError("Lỗi kết nối server."));
    }

    function showResult(res) {
        let html = "";

        if (!res.success) {
            html = `<div class="text-danger">${res.message}</div>`;
        } else {
            res.tickets.forEach(t => {
                html += `
                    <div class="border-bottom border-secondary pb-2 mb-2">
                        <div><b>Phim:</b> ${t.movie}</div>
                        <div><b>Rạp:</b> ${t.theater}</div>
                        <div><b>Phòng:</b> ${t.room}</div>
                        <div><b>Ghế:</b> ${t.seat}</div>
                        <div><b>Suất:</b> ${t.time}</div>
                        <div><b>Thanh toán:</b> ${t.payment}</div>
                    </div>`;
            });
        }

        document.getElementById("modalBody").innerHTML = html;
        new bootstrap.Modal(document.getElementById("resultModal")).show();
    }
</script>



