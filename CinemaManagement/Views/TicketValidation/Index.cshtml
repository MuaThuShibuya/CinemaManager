@{
    ViewData["Title"] = "Kiểm tra vé";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    .validation-container {
        max-width: 800px;
        margin: 0 auto;
        background: #1c1c1c;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 20px rgba(255,0,0,0.2);
    }
    .search-tab {
        display: inline-block;
        padding: 10px 20px;
        margin-bottom: 20px;
        cursor: pointer;
        border-radius: 5px 5px 0 0;
    }
    .search-tab.active {
        background: #ff4d4d;
        color: white;
    }
    .search-tab:not(.active) {
        background: #333;
        color: #ccc;
    }
    .search-panel {
        display: none;
        padding: 20px;
        background: #2a2a2a;
        border-radius: 5px;
    }
    .search-panel.active {
        display: block;
    }
    .result-card {
        background: #222;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
        border-left: 4px solid #ff4d4d;
    }
    .ticket-info {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 10px;
    }
    .ticket-label {
        color: #ffb3b3;
        font-weight: 500;
    }
    .ticket-value {
        color: #fff;
    }
    .btn-validate {
        background: linear-gradient(135deg, #ff4d6d, #ff1f4b);
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }
    .btn-validate:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 10px rgba(255, 77, 109, 0.5);
    }
</style>

@{
    var errorMessage = TempData["ErrorMessage"] as string;
}

<div class="validation-container">
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <h2 class="text-center mb-4"><i class="bi bi-ticket-perforated"></i> KIỂM TRA VÉ</h2>
    <p class="text-center text-muted mb-4">Nhập thông tin để kiểm tra vé của khách hàng</p>

    <div class="mb-4">
        <span class="search-tab active" onclick="showSearch('orderId')">Order ID</span>
        <span class="search-tab" onclick="showSearch('email')">Email</span>
    </div>

    <div id="orderIdPanel" class="search-panel active">
        <h5><i class="bi bi-card-text"></i> Kiểm tra bằng Order ID</h5>
        <form asp-action="ValidateByOrderId" method="post" class="mt-3">
            <div class="mb-3">
                <label for="orderId" class="form-label">Order ID</label>
                <input type="text" class="form-control" id="orderId" name="orderId" 
                       placeholder="Nhập Order ID" required>
            </div>
            <button type="submit" class="btn-validate">
                <i class="bi bi-search"></i> Kiểm tra
            </button>
        </form>
    </div>

    <div id="emailPanel" class="search-panel">
        <h5><i class="bi bi-envelope"></i> Kiểm tra bằng Email</h5>
        <form asp-action="ValidateByEmail" method="post" class="mt-3">
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" name="email"
                       placeholder="Nhập Email" required>
            </div>
            <button type="submit" class="btn-validate">
                <i class="bi bi-search"></i> Kiểm tra
            </button>
        </form>
    </div>
</div>

<script>
    function showSearch(tab) {
        // Hide all panels
        document.querySelectorAll('.search-panel').forEach(p => {
            p.classList.remove('active');
        });
        document.querySelectorAll('.search-tab').forEach(t => {
            t.classList.remove('active');
        });

        // Show selected panel
        document.getElementById(tab + 'Panel').classList.add('active');
        event.target.classList.add('active');
    }
</script>