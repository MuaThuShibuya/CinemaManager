@model IEnumerable<CinemaManagement.Models.Ticket>

@{
    ViewData["Title"] = "Kết quả kiểm tra vé";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    .validation-container {
        max-width: 1000px;
        margin: 0 auto;
        background: #1c1c1c;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 20px rgba(255,0,0,0.2);
    }
    .result-header {
        background: linear-gradient(135deg, #ff4d6d, #ff1f4b);
        color: white;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
    .ticket-card {
        background: #222;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 15px;
        border-left: 4px solid #ff4d4d;
        position: relative;
    }
    .ticket-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 1px solid #444;
    }
    .ticket-title {
        font-size: 1.2rem;
        font-weight: bold;
        color: #ff4d4d;
    }
    .ticket-status {
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
    }
    .status-valid {
        background: #28a745;
        color: white;
    }
    .status-used {
        background: #6c757d;
        color: white;
    }
    .ticket-info {
        display: grid;
        grid-template-columns: 150px 1fr;
        gap: 10px 20px;
        margin-bottom: 15px;
    }
    .ticket-label {
        color: #ffb3b3;
        font-weight: 500;
    }
    .ticket-value {
        color: #fff;
        word-break: break-word;
    }
    .movie-info {
        background: #1a1a1a;
        padding: 15px;
        border-radius: 5px;
        margin-top: 10px;
    }
    .movie-title {
        color: #ffc107;
        font-size: 1.1rem;
        font-weight: bold;
        margin-bottom: 5px;
    }
    .showtime-info {
        color: #fff;
        font-size: 0.9rem;
    }
    .btn-back {
        background: #6c757d;
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        margin-top: 20px;
    }
    .btn-back:hover {
        background: #5a6268;
    }
    .qr-code {
        background: white;
        padding: 10px;
        border-radius: 5px;
        display: inline-block;
        margin-top: 10px;
    }
</style>

<div class="validation-container">
    <div class="result-header">
        <h2><i class="bi bi-ticket-perforated"></i> KẾT QUẢ KIỂM TRA VÉ</h2>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="mb-3">
            <p class="text-white">Tìm thấy <strong>@Model.Count()</strong> vé</p>
        </div>

        @if (ViewBag.UserEmail != null)
        {
            <div class="alert alert-info">
                <i class="bi bi-person"></i> Vé của người dùng: @ViewBag.UserEmail
            </div>
        }
        else if (ViewBag.UserPhone != null)
        {
            <div class="alert alert-info">
                <i class="bi bi-phone"></i> Vé của người dùng: @ViewBag.UserPhone
            </div>
        }

        @foreach (var ticket in Model.OrderByDescending(t => t.Showtime.StartTime))
        {
            <div class="ticket-card">
                <div class="ticket-header">
                    <div class="ticket-title">Vé #@ticket.TicketId</div>
                    <span class="ticket-status status-@(ticket.IsPaid ? "used" : "valid")">
                        @if (ticket.IsPaid)
                        {
                            <i class="bi bi-check-circle"></i> <span>Da thanh toan</span>
                        }
                        else
                        {
                            <i class="bi bi-ticket-perforated"></i> <span>Chua thanh toan</span>
                        }
                    </span>
                </div>

                <div class="ticket-info">
                    <div class="ticket-label">Order ID:</div>
                    <div class="ticket-value">@ticket.OrderId</div>

                    <div class="ticket-label">Rạp:</div>
                    <div class="ticket-value">@ticket.Showtime.Room.Theater.Name (@ticket.Showtime.Room.Theater.City)</div>

                    <div class="ticket-label">Phòng:</div>
                    <div class="ticket-value">@ticket.Showtime.Room.Name</div>

                    <div class="ticket-label">Ghế:</div>
                    <div class="ticket-value">@ticket.Seat.SeatNumber</div>

                    <div class="ticket-label">Giá:</div>
                    <div class="ticket-value">@ticket.Price.ToString("N0") VND</div>

                    <div class="ticket-label">Thời gian mua:</div>
                    <div class="ticket-value">@ticket.BookingTime.ToString("dd/MM/yyyy HH:mm")</div>

                    <div class="ticket-label">Phương thức thanh toán:</div>
                    <div class="ticket-value">@ticket.PaymentMethod</div>
                </div>

                <div class="movie-info">
                    <div class="movie-title">@ticket.Showtime.Movie.Title</div>
                    <div class="showtime-info">
                        <i class="bi bi-clock"></i> @ticket.Showtime.StartTime.ToString("dd/MM/yyyy HH:mm")
                        - @ticket.Showtime.EndTime.ToString("HH:mm")
                    </div>
                </div>

                @if (!ticket.IsPaid)
                {
                    <div class="qr-code">
                        <img src="/api/qr?text=@ticket.TicketId" alt="QR Code" style="width: 100px; height: 100px;">
                    </div>
                }
            </div>
        }

        <a asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="bi bi-info-circle"></i> Không tìm thấy vé nào.
        </div>
        <a asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    }
</div>