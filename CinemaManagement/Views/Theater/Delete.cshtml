@model CinemaManagement.Models.Theater

@{
    ViewData["Title"] = "Xác nhận xóa rạp";
}

<div class="container mt-5">
    <h2 class="mb-4 text-danger"><i class="bi bi-trash"></i> Xác nhận xóa rạp</h2>

    <div class="alert alert-danger shadow-sm">
        <h4>Bạn có chắc chắn muốn xóa rạp <strong>@Model.Name</strong>?</h4>
        <p class="mb-0">Hành động này sẽ xóa toàn bộ phòng chiếu và ghế liên quan. Không thể hoàn tác.</p>
    </div>

    @* Gửi đến Action DeleteConfirmed thông qua Alias "Delete" *@
    <form asp-action="Delete" asp-controller="Theater" method="post">
        @* Quan trọng: name="id" phải khớp với tham số truyền vào hàm DeleteConfirmed *@
        <input type="hidden" name="id" value="@Model.TheaterId" />

        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn btn-danger btn-lg">
                <i class="bi bi-check-circle"></i> Xác nhận xóa
            </button>
            <a asp-action="Index" asp-controller="Theater" class="btn btn-secondary btn-lg">
                <i class="bi bi-x-circle"></i> Hủy bỏ
            </a>
        </div>
    </form>
</div>