@model CinemaManagement.Models.Theater
@{
    ViewData["Title"] = "Chi tiết rạp chiếu";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    .theater-details-card {
        background: #1c1c1c;
        color: #fff;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(255,0,0,0.15);
        margin-bottom: 24px;
        padding: 24px;
    }
    .theater-title {
        font-size: 1.3rem;
        font-weight: bold;
        color: #ff4d4d;
    }
    .theater-location {
        font-size: 1rem;
        color: #ffcccc;
    }
    .theater-city {
        font-size: 0.95rem;
        color: #ffb3b3;
    }
    .room-list {
        margin-top: 24px;
    }
    .room-card {
        background: #222;
        color: #fff;
        border-radius: 8px;
        box-shadow: 0 0 6px rgba(255,0,0,0.10);
        margin-bottom: 16px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .room-title {
        font-size: 1.1rem;
        font-weight: bold;
        color: #ffc107;
    }
    .room-actions {
        margin-top: 8px;
        display: flex;
        gap: 10px;
    }
    .btn-edit-room {
        background: #fff;
        color: #222;
        border-radius: 20px;
        padding: 6px 18px;
        border: none;
        font-weight: 500;
    }
    .btn-edit-room:hover {
        background: #ff4d4d;
        color: #fff;
    }
    .btn-delete-room {
        background: #ff4d4d;
        color: #fff;
        border-radius: 20px;
        padding: 6px 18px;
        border: none;
        font-weight: 500;
    }
    .btn-delete-room:hover {
        background: #222;
        color: #fff;
    }
    .btn-edit-theater {
        background: #0dcaf0;
        color: #222;
        border-radius: 20px;
        padding: 6px 18px;
        border: none;
        font-weight: 500;
        margin-bottom: 12px;
    }
    .btn-edit-theater:hover {
        background: #0a58ca;
        color: #fff;
    }

    .btn-edit-room {
        background: #0dcaf0;
        color: #222;
        border-radius: 20px;
        padding: 6px 18px;
        border: none;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
    }

    .btn-edit-room:hover {
        background: #0a58ca;
        color: #fff;
    }

</style>

<div class="theater-details-card">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="theater-title"><i class="bi bi-film"></i> @Model.Name</div>
        <a asp-action="Edit" asp-route-id="@Model.TheaterId" class="btn-edit-theater"><i class="bi bi-pencil"></i> Sửa rạp</a>
    </div>
    <div class="theater-city"><i class="bi bi-geo-alt"></i> Thành phố: @Model.City</div>
    <div class="theater-location"><i class="bi bi-pin-map"></i> Địa điểm: @Model.Location</div>

    <div class="room-list">
        <h5 class="mb-3"><i class="bi bi-door-open"></i> Danh sách phòng chiếu</h5>
        @if (Model.Rooms == null || !Model.Rooms.Any())
        {
            <div class="alert alert-warning">Rạp chưa có phòng chiếu nào.</div>
        }
        else
        {
            foreach (var room in Model.Rooms)
            {
                <div class="room-card @(room.IsActive ? "" : "inactive-room")">
                    <div class="room-title">
                        <i class="bi bi-tv"></i> @room.Name
                        @if (room.IsActive)
                        {
                            <span class="badge bg-success">Đang hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Ngừng hoạt động</span>
                        }
                    </div>
                    <div>Hệ số giá: <strong>@room.PriceMultiplier</strong></div>
                    <div>Mô tả: <span>@room.Description</span></div>
                    <div>Số ghế: <strong>@(room.Seats?.Count ?? 0)</strong></div>
                    <div class="room-actions">
                        <a asp-action="EditRoom"
                           asp-controller="ManageSeat"
                           asp-route-id="@room.RoomId"
                           class="btn-edit-room">
                           Edit Room
                        </a>

                        @if (room.IsActive)
                        {
                            <form asp-action="DisableRoom" asp-route-id="@room.RoomId" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn ngừng hoạt động phòng này?');">
                                <button type="submit" class="btn-delete-room"><i class="bi bi-power"></i> Ngừng hoạt động</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="EnableRoom" asp-route-id="@room.RoomId" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn bật lại phòng này?');">
                                <button type="submit" class="btn-delete-room" style="background: #28a745;"><i class="bi bi-play-circle"></i> Bật lại</button>
                            </form>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <div class="mt-4">
        <a asp-action="CreateRoom" asp-route-theaterId="@Model.TheaterId" class="btn btn-warning px-4"><i class="bi bi-plus-square"></i> Thêm phòng mới</a>
        <a asp-action="Index" class="btn btn-outline-light px-4"><i class="bi bi-arrow-left"></i> Quay lại danh sách rạp</a>
    </div>
</div>