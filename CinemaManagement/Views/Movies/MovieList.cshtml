@using CinemaManagement.ViewModel
@model TheaterMoviesViewModel

@{
    ViewData["Title"] = "Danh sách phim";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!-- NÚT CHUYỂN PHIM ĐANG CHIẾU / SẮP CHIẾU -->
<div class="container text-center my-4">
    <div class="d-flex justify-content-center gap-4">
        <a href="@Url.Action("NowShowing", "Movies")"
           class="btn @(currentAction == "NowShowing" ? "btn-danger" : "btn-outline-danger")
                  btn-md px-4 py-2 rounded-pill shadow-sm text-uppercase fw-bold"
           style="font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem;">
            Phim đang chiếu
        </a>

        <a href="@Url.Action("ComingSoon", "Movies")"
           class="btn @(currentAction == "ComingSoon" ? "btn-danger" : "btn-outline-danger")
                  btn-md px-4 py-2 rounded-pill shadow-sm text-uppercase fw-bold"
           style="font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem;">
            Phim sắp chiếu
        </a>
    </div>
</div>

<!-- TIÊU ĐỀ -->
@if (currentAction == "NowShowing")
{
    <h2 class="text-center my-4 text-dark fw-bold">🎬 PHIM ĐANG CHIẾU</h2>
}
else if (currentAction == "ComingSoon")
{
    <h2 class="text-center my-4 text-dark fw-bold">🎭 PHIM SẮP CHIẾU</h2>
}
else
{
    <h2 class="text-center my-4 text-dark fw-bold">🎥 MOVIE SELECTION</h2>
}

<!-- DANH SÁCH PHIM -->
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4"
     id="moviesContainer">
    @await Html.PartialAsync("_MovieCardsPartial", Model.Movies)
</div>

@if (!Model.Movies.Any())
{
    <div class="text-center mt-5">
        <i class="fas fa-film fa-3x text-muted mb-3"></i>
        <h4 class="text-muted">Không có phim nào</h4>
        <p class="text-muted">Vui lòng quay lại sau hoặc chọn danh mục khác.</p>
        <a asp-action="Index" asp-controller="Home" class="btn btn-primary">
            Quay về trang chủ
        </a>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {

            function loadMovies() {
                var searchQuery = $('#voiceSearchInput').val();
                var sortBy = $('#sortBy').val();
                var theaterId = $('input[name="theaterId"]').val();
                var time = $('#time').val();
                var action = '@currentAction';

                $.ajax({
                    url: '@Url.Action("FilterAjax", "Movies")',
                    type: 'GET',
                    data: {
                        searchQuery: searchQuery,
                        sortBy: sortBy,
                        theaterId: theaterId,
                        time: time,
                        action: action
                    },
                    success: function (data) {
                        $('#moviesContainer').html(data);
                    },
                    error: function () {
                        alert('Có lỗi khi tải phim!');
                    }
                });
            }

            $('#sortBy, #time, #voiceSearchInput').on('change keyup', loadMovies);
        });
    </script>
}

<style>
    .card img {
        transition: transform .3s ease;
    }

    .card:hover img {
        transform: scale(1.05);
    }
</style>
