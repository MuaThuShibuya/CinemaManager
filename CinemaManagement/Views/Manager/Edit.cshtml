@model CinemaManagement.ViewModel.MovieFormViewModel
@{
    ViewData["Title"] = "Chỉnh sửa phim";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    .form-wrapper {
        max-width: 600px;
        margin: 50px auto;
    }

    .custom-card {
        background-color: #1c1c1c;
        color: #fff;
        border-radius: 10px;
        box-shadow: 0 0 15px rgba(255, 0, 0, 0.3);
    }

    .custom-header {
        background-color: #000;
        padding: 20px;
        text-align: center;
        border-radius: 10px 10px 0 0;
    }

        .custom-header h3 {
            color: #ff4d4d;
            margin: 0;
        }

    .form-label {
        color: #ff4d4d;
        font-weight: bold;
    }

    .form-control {
        background-color: #2c2c2c;
        color: white;
        border: 1px solid #ff4d4d;
    }

        .form-control::placeholder {
            color: #bbbbbb;
        }

    .btn-red {
        background-color: #ff4d4d;
        color: #fff;
        border: none;
    }

        .btn-red:hover {
            background-color: #e60000;
        }

    .btn-outline-light {
        border: 1px solid #fff;
        color: #fff;
    }

        .btn-outline-light:hover {
            background-color: #fff;
            color: #000;
        }

    .text-danger {
        color: #ff6666 !important;
    }

    .form-check-input {
        background-color: #2c2c2c;
        border: 1px solid #ff4d4d;
    }

        .form-check-input:checked {
            background-color: #ff4d4d;
            border-color: #ff4d4d;
        }

    .preview-wrapper {
        width: 100%;
        border: 1px solid #ff4d4d;
        border-radius: 6px;
        overflow: hidden;
        margin-top: 10px;
        background: #000;
    }

    .preview-3x4 {
        aspect-ratio: 3 / 4;
    }

    .preview-16x9 {
        aspect-ratio: 16 / 9;
    }

    .preview-wrapper img,
    .preview-wrapper iframe {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border: none;
    }
</style>

<div class="form-wrapper">
    <div class="custom-card">
        <div class="custom-header">
            <h3><i class="bi bi-pencil-square"></i> Chỉnh sửa phim</h3>
        </div>
        <div class="p-4">
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            }

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @* QUAN TRỌNG: Cần có trường này để không bị lỗi 404/NotFound *@
                <input type="hidden" asp-for="Movie.MovieId" />

                @* Lưu lại các URL ảnh cũ nếu người dùng không upload file mới *@
                <input type="hidden" asp-for="Movie.PosterUrl" />
                <input type="hidden" asp-for="Movie.BannerUrl" />

                <div class="mb-3">
                    <label asp-for="Movie.Title" class="form-label">🎬 Tên phim</label>
                    <input asp-for="Movie.Title" class="form-control" placeholder="Nhập tên phim..." />
                    <span asp-validation-for="Movie.Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Movie.Description" class="form-label">📝 Mô tả phim</label>
                    <textarea asp-for="Movie.Description" class="form-control" placeholder="Nhập mô tả phim..." rows="4"></textarea>
                    <span asp-validation-for="Movie.Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Movie.Duration" class="form-label">⏱ Thời lượng (phút)</label>
                    <input asp-for="Movie.Duration" class="form-control" placeholder="Nhập thời lượng..." />
                    <span asp-validation-for="Movie.Duration" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">🖼 Poster (3:4)</label>
                    <input asp-for="PosterFile" type="file" class="form-control" accept="image/*" id="posterFileInput" />
                    <div class="preview-wrapper preview-3x4">
                        <img id="posterPreview" src="@Model.Movie?.PosterUrl" alt="Poster Preview" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">🎞 Banner (16:9)</label>
                    <input asp-for="BannerFile" type="file" class="form-control" accept="image/*" id="bannerFileInput" />
                    <div class="preview-wrapper preview-16x9">
                        <img id="bannerPreview" src="@Model.Movie?.BannerUrl" alt="Banner Preview" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Movie.VideoUrl" class="form-label">🎥 URL Video (Youtube)</label>
                    <input asp-for="Movie.VideoUrl" class="form-control" placeholder="Nhập URL video..." id="videoInput" />
                    <div class="preview-wrapper preview-16x9 mt-2">
                        <iframe id="videoPreview"
                                src="@Model.Movie?.VideoUrl"
                                allowfullscreen
                                allow="autoplay; encrypted-media">
                        </iframe>
                    </div>
                    <span asp-validation-for="Movie.VideoUrl" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Movie.ReleaseDate" class="form-label">📅 Ngày phát hành</label>
                    <input asp-for="Movie.ReleaseDate" class="form-control" type="date" />
                    <span asp-validation-for="Movie.ReleaseDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">🎭 Thể loại</label>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var genre in Model.Genres)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedGenres" value="@genre.GenreId"
                                       @(Model.SelectedGenres != null && Model.SelectedGenres.Contains(genre.GenreId) ? "checked" : "") />
                                <label class="form-check-label" style="color: #fff;">@genre.Name</label>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="submit" class="btn btn-red px-4">
                        <i class="bi bi-save"></i> Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-outline-light px-4">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>

            @if (User.IsInRole("Admin"))
            {
                <hr class="my-4" />
                <div class="text-end">
                    <a asp-controller="Showtimes" asp-action="Create" asp-route-movieId="@Model.Movie.MovieId" class="btn btn-outline-success me-2 px-4">
                        <i class="bi bi-plus-circle"></i> Thêm suất chiếu mới
                    </a>
                    <a asp-controller="Showtimes" asp-action="Index" asp-route-movieId="@Model.Movie.MovieId" class="btn btn-outline-primary px-4">
                        <i class="bi bi-film"></i> Quản lý suất chiếu
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Preview Poster
        const posterFileInput = document.getElementById('posterFileInput');
        const posterPreview = document.getElementById('posterPreview');
        posterFileInput.addEventListener('change', () => {
            const [file] = posterFileInput.files;
            if (file) {
                posterPreview.src = URL.createObjectURL(file);
            }
        });

        // Preview Banner
        const bannerFileInput = document.getElementById('bannerFileInput');
        const bannerPreview = document.getElementById('bannerPreview');
        bannerFileInput.addEventListener('change', () => {
            const [file] = bannerFileInput.files;
            if (file) {
                bannerPreview.src = URL.createObjectURL(file);
            }
        });

        // Preview Video
        const videoInput = document.getElementById('videoInput');
        const videoPreview = document.getElementById('videoPreview');
        videoInput.addEventListener('input', () => {
            let url = videoInput.value;
            if (url.includes('watch?v=')) {
                url = url.replace('watch?v=', 'embed/');
            } else if (url.includes('youtu.be/')) {
                url = url.replace('youtu.be/', 'www.youtube.com/embed/');
            }
            videoPreview.src = url;
        });
    </script>
}